# FoodScore Environment Configuration
# Copy this file to .env and update values as needed

# Database Configuration
DATABASE_URL=postgresql://foodscore:foodscore_dev_password@postgres:5432/foodscore

# FastAPI Configuration (optional, defaults to localhost:8000)
