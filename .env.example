# FoodScore Environment Configuration
# Copy this file to .env and update values as needed

# Database Connection (used by backend app)
DATABASE_URL=postgresql://foodscore:foodscore_dev_password@postgres:5432/foodscore

# Postgres Container Configuration (used by docker-compose)
DB_USER=foodscore
DB_PASSWORD=foodscore_dev_password
DB_NAME=foodscore

# Backend Configuration
PYTHONUNBUFFERED=1

# FastAPI Configuration (optional, defaults to localhost:8000)
# API_HOST=0.0.0.0
# API_PORT=8000

# OpenFoodFacts API (optional)
# OPENFOODFACTS_API_URL=https://world.openfoodfacts.org/api/v0/product

# Debug Mode (development only)
# DEBUG=True

# Authentication
SECRET_KEY=your-secret-key-here
GOOGLE_CLIENT_ID=your-google-client-id

# Optional: Override specific settings
# DATABASE_URL=postgresql://user:password@postgres:5432/foodscore
# ALLOWED_ORIGINS=http://localhost:3000
