# FoodScore Backend Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=postgresql://foodscore:foodscore_dev_password@localhost:5432/foodscore

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# OpenFoodFacts API
OPENFOODFACTS_API_TIMEOUT=10

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://localhost:8080

# Environment (development, staging, production)
ENVIRONMENT=development
